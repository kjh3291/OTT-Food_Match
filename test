<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineBite - 음식 & 영화 추천</title>
    <style>
        /* CSS: 프론트엔드 스타일 구성 */
        body {
            font-family: 'Pretendard', 'Malgun Gothic', sans-serif;
            background-color: #141414; /* OTT 느낌의 어두운 배경 */
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .container {
            background-color: #222;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: 500px;
        }

        h1 {
            text-align: center;
            color: #E50914; /* 넷플릭스 레드 포인트 */
            margin-bottom: 30px;
        }

        .section {
            background-color: #333;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        h2 {
            font-size: 1.2rem;
            margin-top: 0;
            margin-bottom: 15px;
            border-bottom: 1px solid #555;
            padding-bottom: 10px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            margin-bottom: 15px;
        }

        label {
            margin-bottom: 5px;
            font-size: 0.9rem;
            color: #aaa;
        }

        select {
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #555;
            background-color: #444;
            color: white;
            font-size: 1rem;
            outline: none;
        }

        button {
            width: 100%;
            padding: 12px;
            background-color: #E50914;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s;
            margin-top: 10px;
        }

        button:hover {
            background-color: #f6121d;
        }

        .result-box {
            margin-top: 15px;
            padding: 15px;
            background-color: #1a1a1a;
            border-left: 4px solid #E50914;
            border-radius: 4px;
            display: none; /* 초기에는 숨김 */
            line-height: 1.5;
        }

        .result-box.active {
            display: block;
            animation: fadeIn 0.5s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>🍿 CineBite 🍕</h1>

        <div class="section">
            <h2>배달 메뉴로 영화 찾기</h2>
            <div class="form-group">
                <label for="food-select">지금 땡기는 음식은?</label>
                <select id="food-select">
                    <option value="chicken">치킨 & 맥주</option>
                    <option value="pizza">피자</option>
                    <option value="spicy">매운 떡볶이 / 마라탕</option>
                    <option value="snack">팝콘 & 나초</option>
                </select>
            </div>
            <button onclick="recommendMovie()">영화 추천받기</button>
            <div id="movie-result" class="result-box"></div>
        </div>

        <div class="section">
            <h2>보는 콘텐츠로 음식 찾기</h2>
            <div class="form-group">
                <label for="ott-select">이용 중인 OTT 플랫폼</label>
                <select id="ott-select">
                    <option value="Netflix">넷플릭스</option>
                    <option value="Watcha">왓챠</option>
                    <option value="Tving">티빙</option>
                    <option value="Disney">디즈니+</option>
                </select>
            </div>
            <div class="form-group">
                <label for="genre-select">영화 장르</label>
                <select id="genre-select">
                    <option value="action">액션 / 블록버스터</option>
                    <option value="romance">로맨스 / 멜로</option>
                    <option value="thriller">스릴러 / 공포</option>
                    <option value="comedy">코미디 / 예능</option>
                </select>
            </div>
            <div class="form-group">
                <label for="mood-select">원하는 분위기</label>
                <select id="mood-select">
                    <option value="exciting">신나는</option>
                    <option value="chill">편안하고 잔잔한</option>
                    <option value="tense">긴장감 넘치는</option>
                </select>
            </div>
            <button onclick="recommendFood()">음식 추천받기</button>
            <div id="food-result" class="result-box"></div>
        </div>
    </div>

    <script>
        /* JavaScript: 추천 로직 구현 */

        // 음식 데이터 베이스 (음식 -> 영화 매핑)
        const foodToMovieDB = {
            'chicken': {
                title: '극한직업',
                genre: '코미디/액션',
                reason: '치킨을 먹으면서 볼 때는 역시 치킨이 나오는 유쾌한 코미디가 최고죠!'
            },
            'pizza': {
                title: '닌자터틀',
                genre: '액션',
                reason: '피자를 사랑하는 돌연변이 거북이들과 함께 액션을 즐겨보세요.'
            },
            'spicy': {
                title: '매드맥스: 분노의 도로',
                genre: '액션/스릴러',
                reason: '매운맛으로 스트레스를 풀 땐, 화끈하게 터지는 블록버스터가 제격입니다.'
            },
            'snack': {
                title: '어벤져스 시리즈',
                genre: 'SF/액션',
                reason: '끊임없이 손이 가는 스낵에는 눈을 뗄 수 없는 팝콘 무비의 정석을 추천합니다.'
            }
        };

        // 장르 데이터 베이스 (영화/장르 -> 음식 매핑)
        const genreToFoodDB = {
            'action': {
                food: '수제버거 세트 🍔',
                reason: '빠르고 화려한 액션에는 든든하고 캐주얼하게 즐길 수 있는 햄버거가 잘 어울려요.'
            },
            'romance': {
                food: '달콤한 디저트와 와인 🍰🍷',
                reason: '달달한 로맨스 분위기를 한층 더 끌어올려 줄 달콤한 조합입니다.'
            },
            'thriller': {
                food: '마른 오징어와 맥주 🦑🍺',
                reason: '긴장해서 입이 바짝바짝 마를 때, 오래 씹을 수 있는 안주와 시원한 맥주가 필요합니다.'
            },
            'comedy': {
                food: '피자와 치킨 (피나치공) 🍕🍗',
                reason: '생각 없이 웃고 떠들며 보기에는 푸짐하고 맛있는 배달 음식의 황제들이 딱입니다.'
            }
        };

        // 영화 추천 함수
        function recommendMovie() {
            const selectedFood = document.getElementById('food-select').value;
            const resultBox = document.getElementById('movie-result');
            const data = foodToMovieDB[selectedFood];

            resultBox.innerHTML = `
                <strong>🎬 추천 영화: ${data.title} (${data.genre})</strong><br><br>
                💡 <strong>추천 이유:</strong> ${data.reason}
            `;
            resultBox.classList.add('active');
        }

        // 음식 추천 함수
        function recommendFood() {
            const ott = document.getElementById('ott-select').value;
            const genre = document.getElementById('genre-select').value;
            const moodDropdown = document.getElementById('mood-select');
            const moodText = moodDropdown.options[moodDropdown.selectedIndex].text;
            
            const resultBox = document.getElementById('food-result');
            const data = genreToFoodDB[genre];

            resultBox.innerHTML = `
                <strong>🍔 추천 음식: ${data.food}</strong><br><br>
                💡 <strong>추천 세팅:</strong> ${ott}에서 ${moodText} 분위기의 작품을 고르셨네요! <br>${data.reason}
            `;
            resultBox.classList.add('active');
        }
    </script>

</body>
</html>